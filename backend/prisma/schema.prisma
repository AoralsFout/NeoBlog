generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  natayark_id Int      @unique
  username    String
  email       String   @unique
  avatar      String?
  role        Role     @default(MEMBER)
  status      Status   @default(NORMAL)
  last_login  DateTime?
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @updatedAt @map("updated_at")

  comments         Comment[]
  commentReactions CommentReaction[]

  @@map("users")
}

enum Role {
  ADMIN
  MEMBER
}

enum Status {
  NORMAL
  BANNED
  FROZEN
}

model Music {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  album       String
  mainColor  String   @map("mainColor")
  language    String
  isTranslate Boolean @map("isTranslate")
  format      String

  @@map("musics")
}

enum ReactionType {
  LIKE
  DISLIKE
}

model Comment {
  id             Int               @id @default(autoincrement())
  content        String
  source_id      String           @db.VarChar(100)
  source_type    String           @db.VarChar(20)
  user_id        Int
  parent_id      Int?
  likes_count    Int               @default(0)
  dislikes_count Int               @default(0)
  created_at     DateTime          @default(now()) @map("created_at")
  updated_at     DateTime          @updatedAt @map("updated_at")

  user           User              @relation(fields: [user_id], references: [id])
  parent         Comment?          @relation("CommentReplies", fields: [parent_id], references: [id])
  replies        Comment[]         @relation("CommentReplies")
  reactions      CommentReaction[]

  @@index([source_id, source_type])
  @@index([parent_id])
  @@map("comments")
}

model CommentReaction {
  id         Int          @id @default(autoincrement())
  comment_id Int
  user_id    Int
  type       ReactionType
  created_at DateTime     @default(now()) @map("created_at")

  comment    Comment      @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [user_id], references: [id])

  @@unique([comment_id, user_id])
  @@map("comment_reactions")
}